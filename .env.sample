# Copy to `.env` and adjust. See README for full variable list.

# Comma-separated list of allowed CORS origins. Leave unset to allow all (dev default).
# CORS_ORIGINS=http://localhost:3000,https://gym.example.com

# Max API requests per IP per 15-minute window (default 1000).
# RATE_LIMIT_MAX=1000

# Set to 1 to log full ESP32 webhook JSON bodies and request headers (verbose debugging).
# DEBUG_BIOMETRIC_WEBHOOK=1
