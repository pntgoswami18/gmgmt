# Copy to `.env` and adjust. See README for full variable list.

# Comma-separated list of allowed CORS origins. Leave unset to allow all (dev default).
# CORS_ORIGINS=http://localhost:3000,https://gym.example.com

# Max API requests per IP per 15-minute window (default 1000).
# RATE_LIMIT_MAX=1000

# Set to 1 to log full ESP32 webhook JSON bodies and request headers (verbose debugging).
# DEBUG_BIOMETRIC_WEBHOOK=1

# Secret used to sign staff login session tokens. Required — the server refuses to
# start without it. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# How long a staff session stays valid before requiring another login (default 12h).
# JWT_EXPIRES_IN=12h

# Seeds one admin account on first boot if the staff table is empty. Only used once —
# ignored after any staff account exists. Change the password after first login.
# INITIAL_ADMIN_USERNAME=admin
# INITIAL_ADMIN_PASSWORD=

# Shared secret ESP32 devices must send as the X-Device-Secret header when calling
# the webhook/validate/cache-update/firmware-download endpoints. Leave unset in dev
# (the check is skipped); set it once all deployed devices have the firmware that
# sends this header, so devices aren't locked out mid-rollout. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DEVICE_SHARED_SECRET=
